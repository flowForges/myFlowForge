# Download Electron's prebuilt binaries from the npmmirror mirror instead of GitHub releases.
# The direct GitHub download corrupts behind some proxies ("extra bytes at beginning of zipfile"),
# which leaves node_modules/electron/dist incomplete and makes electron-builder fail with
# "corrupted electron dist" (electron-builder.yml pins electronDist to that local dist). The mirror
# serves intact zips, so electron installs a valid per-arch dist on every machine.
electron_mirror=https://npmmirror.com/mirrors/electron/
